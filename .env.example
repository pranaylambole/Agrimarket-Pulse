# APP_URL: The base URL where this app is hosted.
# For local development, this is typically http://localhost:3000
# Update this to your production URL when deploying.
APP_URL="http://localhost:3000"

# Firebase Configuration
# Copy your Firebase project config and prefix each key with VITE_ so Vite exposes them to the browser.
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

